# OpenAI
OPENAI_API_KEY=sk-...

# Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=...

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/construction_archive

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=construction_blueprints

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# ColPali
COLPALI_MODEL_NAME=vidore/colpali-v1.2
COLPALI_DEVICE=cpu

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./archive_output

# FastAPI
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000

# Next.js
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
